# sudo works with aliases
alias sudo='sudo '

# neofetch is fastfetch
alias neofetch='fastfetch'

# cd into icloud drive directory
alias cdi='cd ~/Library/Mobile\ Documents/com\~apple\~CloudDocs'

# output file without comments
sc() {
	grep ^[^#] $1
}

# netcat udp hostname port
alias nc-u='nc -u -zv'

# netcat tcp hostname port
alias nc-t='nc -t -zv'

# view aliases
alias aliases='grep -Ev "^[[:space:]]*(#|$)" ~/Code/jakegiorlando/dotfiles/.mac_aliases'
alias cdipa='cd /Users/ipa/jake'
alias cdbrew='cd /opt/homebrew'
#alias mssh='osascript ${HOME}/scripts/ssh_grid.applescript'
