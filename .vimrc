" syntax highlighting on
syntax on

" highlight search
"set hlsearch

" auto indent
set autoindent

" disable mouse (so selecting with mouse works normally)
"set mouse=

" enable mouse
set mouse=a

" enable line wrapping
set wrap

" keep wrapped lines visually indented
set breakindent

" don't break words when wrapping
set linebreak

" chracters to break on
set breakat=\ \ ;:,!?
